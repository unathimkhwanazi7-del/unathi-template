{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "unathi-template",
	"compatibility_date": "2025-10-08",
	"main": "./workers/app.ts",
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	"kv_namespaces": [
		{
			"binding": "AEO_KV",
			"id": "19b8c57a93a3432a9165b09741e6ffb4"
		}
	],
	"queues": {
		"producers": [
			{
				"queue": "brand-visibility-jobs",
				"binding": "BRAND_VISIBILITY_QUEUE"
			}
		],
		"consumers": [
			{
				"queue": "brand-visibility-jobs",
				"max_batch_size": 5,
				"max_concurrency": 10
			}
		]
	}
}
